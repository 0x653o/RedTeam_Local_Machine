# ──────────────────────────────────────────────────────
# Local-Machine — Global Configuration
# ──────────────────────────────────────────────────────

# Flag seed — change this to regenerate all flags
# IMPORTANT: Keep this secret in production deployments
FLAG_SEED=change-me-to-a-random-string-$(date +%s)

# Network configuration
SUBNET_BASE=10.10
INFRA_SUBNET=${SUBNET_BASE}.0.0/24

# VPN configuration
VPN_PORT=51820
VPN_SUBNET=${SUBNET_BASE}.254.0/24
VPN_SERVER_IP=${SUBNET_BASE}.254.1

# Portal configuration
PORTAL_PORT=8443
PORTAL_SECRET=change-me-portal-secret

# Lifecycle manager
MAX_INSTANCE_LIFETIME_MINUTES=60
HEALTH_CHECK_INTERVAL_SECONDS=30
LOG_RETENTION_DAYS=7
LOG_DIR=/var/log/local-machine

# Escape challenges (NEVER enable on shared/production hosts)
ENABLE_ESCAPE_CHALLENGES=false

# Machine count
TOTAL_MACHINES=42
