# ──────────────────────────────────────────────────────────────────
# Local-Machine — Global Configuration
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SCENARIO QUICK-SELECT — uncomment the block that matches your setup:
#
#   A) Local dev     → ENABLE_VPN=false, SERVER_IP=127.0.0.1
#   B) Homelab / VPS → ENABLE_VPN=true,  SERVER_IP=<your public IP>
#   C) School (open port) → ENABLE_VPN=true, SERVER_IP=<campus public IP>
#   D) School (outbound-only) → ENABLE_VPN=true, SERVER_IP=<tailscale IP 100.x.x.x>
#
# Full setup docs: implementation_plan.md § 3.6
# ──────────────────────────────────────────────────────────────────

# ── Secrets ───────────────────────────────────────────────────────
# Flag seed — change this to regenerate all flags
# IMPORTANT: Keep this secret. Change for every new session/class.
FLAG_SEED=change-me-to-a-random-string

# Portal access secret (used by admin login)
PORTAL_SECRET=change-me-portal-secret

# ── Server Identity ───────────────────────────────────────────────
# Your public / dedicated / Tailscale IP address.
# This is baked into generated .ovpn files as the Endpoint.
# Leave blank to auto-detect via ifconfig.me (requires internet).
#
#   Scenario A (local dev):           SERVER_IP=127.0.0.1
#   Scenario B (homelab/VPS):         SERVER_IP=<your public IP>
#   Scenario C (school open port):    SERVER_IP=<campus public IP>
#   Scenario D (school outbound-only):SERVER_IP=<tailscale IP, e.g. 100.64.0.10>
SERVER_IP=

# ── VPN (OpenVPN) ─────────────────────────────────────────────────
# Protocol and port the OpenVPN server listens on.
# Scenario C: change VPN_PORT to whatever port the school admin approved.
VPN_PORT=1194
VPN_PROTO=udp

# Enable or disable the OpenVPN container.
# Set to false for Scenario A (local dev — no VPN needed).
# Set to true for all other scenarios.
ENABLE_VPN=true

# ── Portal ────────────────────────────────────────────────────────
# Port the web portal HTTPS server listens on.
PORTAL_PORT=8443

# Public URL used in emails / links (if behind Cloudflare Tunnel — Scenario D).
# Leave blank for direct IP access.
#   Scenario D example: PORTAL_PUBLIC_URL=https://lab.yourdomain.com
PORTAL_PUBLIC_URL=

# ── Kubernetes ───────────────────────────────────────────────────
# kubectl context to use (usually 'default' for k3s).
K8S_CONTEXT=default

# ── Network ───────────────────────────────────────────────────────
SUBNET_BASE=10.10
INFRA_SUBNET=${SUBNET_BASE}.0.0/24

# ── Lifecycle Manager ────────────────────────────────────────────
# How long a machine Pod can run before auto-reset.
MAX_INSTANCE_LIFETIME_MINUTES=60
HEALTH_CHECK_INTERVAL_SECONDS=30
LOG_RETENTION_DAYS=7
LOG_DIR=/var/log/local-machine

# ── Escape Challenges ─────────────────────────────────────────────
# NEVER enable on shared or production hosts.
# Only enable inside a disposable VM.
ENABLE_ESCAPE_CHALLENGES=false

# ── Stats ─────────────────────────────────────────────────────────
TOTAL_MACHINES=42
